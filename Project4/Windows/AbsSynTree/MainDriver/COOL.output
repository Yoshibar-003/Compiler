Grammar

    0 $accept: program $end

    1 program: class_list

    2 class_list: class
    3           | class class_list

    4 class: CLASS TYPEID '{' optional_feature_list '}' ';'
    5      | CLASS TYPEID INHERITS TYPEID '{' optional_feature_list '}' ';'

    6 optional_feature_list: /* empty */
    7                      | feature_list

    8 feature_list: feature ';'
    9             | feature ';' feature_list

   10 feature: OBJECTID '(' optional_formal_list ')' ':' TYPEID '{' expr '}'
   11        | OBJECTID ':' TYPEID
   12        | OBJECTID ':' TYPEID ASSIGN expr

   13 optional_formal_list: /* empty */
   14                     | formal_list

   15 formal_list: formal
   16            | formal ',' formal_list

   17 formal: OBJECTID ':' TYPEID

   18 expr: OBJECTID ASSIGN expr
   19     | expr '.' OBJECTID '(' optional_arg_list ')'
   20     | expr '@' TYPEID '.' OBJECTID '(' optional_arg_list ')'
   21     | OBJECTID '(' optional_arg_list ')'
   22     | IF expr THEN expr ELSE expr FI
   23     | WHILE expr LOOP expr POOL
   24     | '{' expr_seq '}'
   25     | LET let_list
   26     | CASE expr OF case_branch_list ESAC
   27     | NEW TYPEID
   28     | ISVOID expr
   29     | '~' expr
   30     | NOT expr
   31     | expr '+' expr
   32     | expr '-' expr
   33     | expr '*' expr
   34     | expr '/' expr
   35     | expr '<' expr
   36     | expr LE expr
   37     | expr '=' expr
   38     | '(' expr ')'
   39     | OBJECTID
   40     | INT_CONST
   41     | STR_CONST
   42     | BOOL_CONST

   43 optional_arg_list: /* empty */
   44                  | arg_list

   45 arg_list: expr
   46         | expr ',' arg_list

   47 expr_seq: expr ';'
   48         | expr ';' expr_seq

   49 let_list: let_binding IN expr
   50         | let_binding ',' let_list

   51 let_binding: OBJECTID ':' TYPEID
   52            | OBJECTID ':' TYPEID ASSIGN expr

   53 case_branch_list: case_branch
   54                 | case_branch case_branch_list

   55 case_branch: OBJECTID ':' TYPEID DARROW expr ';'


