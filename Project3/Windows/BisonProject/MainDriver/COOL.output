State 5 conflicts: 1 shift/reduce
State 10 conflicts: 1 shift/reduce


Grammar

    0 $accept: program $end

    1 program: class_list

    2 class_list: class
    3           | error ';'
    4           | class class_list
    5           | class_list error ';'

    6 class: CLASS TYPEID '{' optional_feature_list '}' ';'
    7      | CLASS TYPEID INHERITS TYPEID '{' optional_feature_list '}' ';'

    8 optional_feature_list: /* empty */
    9                      | feature_list

   10 feature_list: feature ';'
   11             | feature ';' feature_list
   12             | error ';' feature_list
   13             | error ';'

   14 feature: OBJECTID '(' optional_formal_list ')' ':' TYPEID '{' expr '}'
   15        | OBJECTID ':' TYPEID
   16        | OBJECTID ':' TYPEID ASSIGN expr

   17 optional_formal_list: /* empty */
   18                     | formal_list

   19 formal_list: formal
   20            | formal ',' formal_list

   21 formal: OBJECTID ':' TYPEID

   22 expr: OBJECTID ASSIGN expr
   23     | expr '.' OBJECTID '(' optional_arg_list ')'
   24     | expr '@' TYPEID '.' OBJECTID '(' optional_arg_list ')'
   25     | OBJECTID '(' optional_arg_list ')'
   26     | IF expr THEN expr ELSE expr FI
   27     | WHILE expr LOOP expr POOL
   28     | '{' expr_seq '}'
   29     | LET let_binding_list IN expr
   30     | CASE expr OF case_branch_list ESAC
   31     | NEW TYPEID
   32     | ISVOID expr
   33     | '~' expr
   34     | NOT expr
   35     | expr '+' expr
   36     | expr '-' expr
   37     | expr '*' expr
   38     | expr '/' expr
   39     | expr '<' expr
   40     | expr LE expr
   41     | expr '=' expr
   42     | '(' expr ')'
   43     | OBJECTID
   44     | INT_CONST
   45     | STR_CONST
   46     | BOOL_CONST

   47 optional_arg_list: /* empty */
   48                  | arg_list
   49                  | error

   50 arg_list: expr
   51         | expr ',' arg_list
   52         | expr error arg_list
   53         | expr ',' error

   54 expr_seq: expr ';'
   55         | expr ';' expr_seq
   56         | error ';' expr_seq
   57         | error ';'

   58 let_binding_list: let_binding
   59                 | let_binding ',' let_binding_list

   60 let_binding: OBJECTID ':' TYPEID
   61            | OBJECTID ':' TYPEID ASSIGN expr

   62 case_branch_list: case_branch
   63                 | case_branch case_branch_list

   64 case_branch: OBJECTID ':' TYPEID DARROW expr ';'


